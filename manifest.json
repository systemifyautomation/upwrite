{
  "manifest_version": 3,
  "name": "UpWrite – Upwork Proposal Assistant",
  "short_name": "UpWrite",
  "version": "1.0.0",
  "description": "Extract Upwork proposal details, record a Loom video, and auto-generate AI proposals via your n8n webhook.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "UpWrite",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.upwork.com/nx/proposals/*",
        "https://www.upwork.com/ab/proposals/*",
        "https://www.upwork.com/proposals/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; media-src blob: 'self';"
  },
  "permissions": [
    "activeTab",
    "storage",
    "unlimitedStorage",
    "scripting",
    "alarms",
    "offscreen",
    "desktopCapture",
    "tabs",
    "notifications"
  ],
  "host_permissions": [
    "https://www.upwork.com/*",
    "<all_urls>"
  ]
}
