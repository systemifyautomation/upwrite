{
  "manifest_version": 3,
  "name": "Upright – Upwork Proposal Assistant",
  "short_name": "Upright",
  "version": "1.0.0",
  "description": "Extract Upwork proposal details, record a Loom video, and auto-generate AI proposals via your n8n webhook.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Upright",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.upwork.com/nx/proposals/*",
        "https://www.upwork.com/ab/proposals/*",
        "https://www.upwork.com/proposals/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://www.upwork.com/*"
  ]
}
